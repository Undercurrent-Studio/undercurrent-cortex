{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [{
          "type": "command",
          "command": "\"C:/Program Files/Git/bin/bash.exe\" \"C:/Users/whflo/.claude/plugins/cache/claude-plugins-official/undercurrent/55b58ec6e564/hooks/session-start\"",
          "async": false
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "\"C:/Program Files/Git/bin/bash.exe\" \"C:/Users/whflo/.claude/plugins/cache/claude-plugins-official/undercurrent/55b58ec6e564/hooks/scripts/post-bash-dispatch.sh\"",
          "async": false
        }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{
          "type": "command",
          "command": "\"C:/Program Files/Git/bin/bash.exe\" \"C:/Users/whflo/.claude/plugins/cache/claude-plugins-official/undercurrent/55b58ec6e564/hooks/scripts/post-edit-dispatch.sh\"",
          "async": false
        }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/Git/bin/bash.exe\" \"C:/Users/whflo/.claude/plugins/cache/claude-plugins-official/undercurrent/55b58ec6e564/hooks/scripts/migration-linter.sh\"",
            "async": false
          },
          {
            "type": "prompt",
            "prompt": "Check the tool input. If the file_path contains 'src/app/(dashboard)/', inject this reminder: 'Dashboard route detected. Verify: (1) middleware.ts matcher includes this path, (2) API routes have path.startsWith() auth, (3) server components use getUser(). See security-posture skill.'"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [{
          "type": "command",
          "command": "\"C:/Program Files/Git/bin/bash.exe\" \"C:/Users/whflo/.claude/plugins/cache/claude-plugins-official/undercurrent/55b58ec6e564/hooks/scripts/plan-file-guard.sh\"",
          "async": false
        }]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [{
          "type": "prompt",
          "prompt": "Before context compaction: scan the current conversation for any text tagged [carry-over] or [mid-session pin]. If found, summarize them as a systemMessage so they survive compaction. If none found, do nothing."
        }]
      }
    ]
  }
}
